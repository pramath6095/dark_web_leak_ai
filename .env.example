# Tor proxy settings
TOR_PROXY_HOST=127.0.0.1
TOR_PROXY_PORT=9150

# === AI Provider Selection ===
# Options: gemini | ollama | anthropic | deepseek | groq | mistral
AI_PROVIDER=

# === Gemini (default) ===
# REFINE key is the fallback if other stage keys are not set
GEMINI_KEY_REFINE=
GEMINI_KEY_FILTER=
GEMINI_KEY_CLASSIFY=
GEMINI_KEY_SUMMARY=
GEMINI_KEY_FILE_ANALYSIS=

# === Anthropic ===
ANTHROPIC_KEY_REFINE=
ANTHROPIC_KEY_FILTER=
ANTHROPIC_KEY_CLASSIFY=
ANTHROPIC_KEY_SUMMARY=
ANTHROPIC_KEY_FILE_ANALYSIS=

# === DeepSeek ===
DEEPSEEK_KEY_REFINE=
DEEPSEEK_KEY_FILTER=
DEEPSEEK_KEY_CLASSIFY=
DEEPSEEK_KEY_SUMMARY=
DEEPSEEK_KEY_FILE_ANALYSIS=

# === Groq ===
GROQ_KEY_REFINE=
GROQ_KEY_FILTER=
GROQ_KEY_CLASSIFY=
GROQ_KEY_SUMMARY=
GROQ_KEY_FILE_ANALYSIS=

# === Mistral ===
MISTRAL_KEY_REFINE=
MISTRAL_KEY_FILTER=
MISTRAL_KEY_CLASSIFY=
MISTRAL_KEY_SUMMARY=
MISTRAL_KEY_FILE_ANALYSIS=

# === Ollama (local model) ===
OLLAMA_BASE_URL=http://localhost:11434

# === Forum Authentication ===
FORUM_ACCOUNTS_FILE=output/forum_accounts.json
FORUM_AUTO_REGISTER=true

# === CAPTCHA Solving ===
# Service: 2captcha or anticaptcha (~$1-3 per 1000 solves)
CAPTCHA_API_KEY=
CAPTCHA_SERVICE=2captcha
