PROTONVPN_USER=username
PROTONVPN_PASS=password
TOR_PROXY_HOST=127.0.0.1
TOR_PROXY_PORT=9150

# primary fallback key (used if stage-specific keys are not set)
GEMINI_API_KEY=your_gemini_api_key_here

# per-stage keys for rate limit distribution (optional)
GEMINI_KEY_REFINE=
GEMINI_KEY_FILTER=
GEMINI_KEY_CLASSIFY=
GEMINI_KEY_SUMMARY=

# ollama fallback (optional, for local models)
OLLAMA_BASE_URL=http://localhost:11434
