# Tor proxy settings
TOR_PROXY_HOST=127.0.0.1
TOR_PROXY_PORT=9150

# primary fallback key (used if stage-specific keys are not set)
GEMINI_API_KEY=your_gemini_api_key_here

# per-stage keys from separate accounts for rate limit distribution
# (optional — falls back to GEMINI_API_KEY if not set)
GEMINI_KEY_REFINE=
GEMINI_KEY_FILTER=
GEMINI_KEY_CLASSIFY=
GEMINI_KEY_SUMMARY=
GEMINI_KEY_FILE_ANALYSIS=

# ollama fallback (optional)
OLLAMA_BASE_URL=http://localhost:11434
